# Absolute paths
REPO_DIR=/opt/RetroPRO
APP_DIR=/opt/RetroPRO/retro_star
PYTHON_BIN=/opt/miniconda3/envs/retro_star_env/bin/python

# Bind loopback only; nginx provides external access
RETROTMP_HOST=127.0.0.1
RETROTMP_PORT=18000

# Starting molecules file path (env override for main.py)
RETROTMP_STARTING_MOLS_PATH=/opt/RetroPRO/retro_star/dataset/origin_dict.csv
